generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id              String    @id @default(uuid())
  name            String
  nameEn          String    @default("")
  code            String    @unique
  category        String
  baseMaterial    String?
  description     String
  descriptionEn   String    @default("")
  specs           String?
  image           String?
  priceHint       String?
  featured        Boolean   @default(false)
  applicationTags String?   // JSON array string: ["packaging","automotive","electrical"]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  inquiries       Inquiry[]
  attributes      ProductAttribute[]
}

model ProductAttribute {
  id        String  @id @default(uuid())
  productId String
  key       String  // density, tensileStrength, meltFlowRate, etc.
  labelZh   String  // 中文标签
  labelEn   String  // 英文标签
  value     String  // 数值或文本（中文）
  valueEn   String  @default("") // 英文值
  unit      String? // 单位
  category  String  // physical / thermal / mechanical / chemical / processing / application
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  phone     String?
  whatsapp  String?
  country   String?
  city      String?
  message   String
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
